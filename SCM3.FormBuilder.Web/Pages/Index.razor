@page "/"
@using SCM3.FormBuilder.UI.Designer
@using SCM3.FormBuilder.UI.Renderer
@using SCM3.FormBuilder.UI.Viewer
@using SCM3.FormBuilder.UI.Dashboard
@using SCM3.FormBuilder.UI.Manager
@using SCM3.FormBuilder.Core.Models

<h1>SCM3 Form Builder - POC</h1>

<!-- Top-level navigation -->
<div style="display:flex;gap:8px;margin-bottom:16px">
    <button class="@(_topMode == "artifacts" ? "active" : "")" @onclick="@(() => _topMode = "artifacts")" style="padding:8px 16px;cursor:pointer">Artifacts</button>
    <button class="@(_topMode == "forms" ? "active" : "")" @onclick="@(() => { _topMode = "forms"; _selectedFormKey = ""; })" style="padding:8px 16px;cursor:pointer">Forms</button>
</div>

@if (_topMode == "artifacts")
{
    <!-- ========== ARTIFACTS WORKFLOW (Data Collection) ========== -->
    @if (_selectedArtifact == null)
    {
        <!-- Show artifact list -->
        <ArtifactsManager OnArtifactSelected="SelectArtifactAndAutoForm" />
    }
    else
    {
        <!-- Artifact selected: Show Renderer and Submissions with auto-selected form -->
        <div style="display:flex;gap:8px;margin-bottom:16px;align-items:center">
            <button class="@(_artifactMode == "renderer" ? "active" : "")" @onclick="@(() => _artifactMode = "renderer")" style="padding:8px 16px;cursor:pointer">Fill Form</button>
            <button class="@(_artifactMode == "submissions" ? "active" : "")" @onclick="@(() => _artifactMode = "submissions")" style="padding:8px 16px;cursor:pointer">View Submissions</button>
            <button class="fb-btn-secondary" @onclick="@(() => { _selectedArtifact = null; _selectedFormKey = ""; })" style="padding:8px 16px;cursor:pointer;margin-left:auto">← Back to Artifacts</button>
        </div>

        <p><strong>Artifact:</strong> @_selectedArtifact.ArtifactId (@_selectedArtifact.Type) | <strong>Form:</strong> @_selectedFormKey</p>

        @if (_artifactMode == "renderer")
        {
            <FormRenderer FormKey="@_selectedFormKey" ToolType="@_selectedToolType" RecordPrimaryKey="@_selectedArtifact.ArtifactId" />
        }
        else if (_artifactMode == "submissions")
        {
            <SubmissionsViewer ToolType="@_selectedToolType" FormKey="@_selectedFormKey" />
        }
    }
}
else
{
    <!-- ========== FORMS WORKFLOW (Design/Admin) ========== -->
    @if (string.IsNullOrEmpty(_selectedFormKey))
    {
        <!-- Show form list for design -->
        <AdminDashboard OnFormSelected="SelectFormForDesign" />
    }
    else
    {
        <!-- Form selected: Show Designer only -->
        <div style="display:flex;gap:8px;margin-bottom:16px;align-items:center">
            <button class="fb-btn-secondary" @onclick="BackToDashboard" style="padding:8px 16px;cursor:pointer">← Back to Forms</button>
        </div>

        <p><strong>Designing Form:</strong> @_selectedFormKey</p>

        <FormDesigner ToolType="@_selectedToolType" FormKey="@_selectedFormKey" />
    }
}

@code {
    private string _topMode = "forms";
    private string _mode = "designer";
    private string _artifactMode = "renderer";
    private string? _statusMessage;
    private string _selectedToolType = "ArtifactForms";
    private string _selectedFormKey = "";
    private Artifact? _selectedArtifact;

    // Mapping of artifact type to form key
    private readonly Dictionary<string, string> ArtifactTypeToFormKey = new()
    {
        { "CSCI", "CSCI-Form" },
        { "Segment", "Segment-Form" },
        { "System", "System-Form" }
    };

    // Select artifact and auto-select the matching form
    private void SelectArtifactAndAutoForm(Artifact artifact)
    {
        _selectedArtifact = artifact;

        // Auto-select form based on artifact type
        if (ArtifactTypeToFormKey.TryGetValue(artifact.Type, out var formKey))
        {
            _selectedFormKey = formKey;
            _selectedToolType = "ArtifactForms";
            _artifactMode = "renderer";
        }

        StateHasChanged();
    }

    // For Forms workflow (design only)
    private void SelectFormForDesign((string ToolType, string FormKey) form)
    {
        _selectedToolType = form.ToolType;
        _selectedFormKey = form.FormKey;
        StateHasChanged();
    }

    // For Artifacts workflow (data collection only)
    private void SelectFormForArtifact((string ToolType, string FormKey) form)
    {
        _selectedToolType = form.ToolType;
        _selectedFormKey = form.FormKey;
        _artifactMode = "renderer";
        StateHasChanged();
    }

    private void BackToDashboard()
    {
        _selectedToolType = "";
        _selectedFormKey = "";
        _selectedArtifact = null;
        _mode = "designer";
        _topMode = "forms";
        StateHasChanged();
    }

    private void SwitchToDesigner()
    {
        _mode = "designer";
    }

    private void SwitchToRenderer()
    {
        _mode = "renderer";
    }

    private void SwitchToSubmissions()
    {
        _mode = "submissions";
    }
}
