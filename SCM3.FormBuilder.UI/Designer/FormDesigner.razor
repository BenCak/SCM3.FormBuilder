@namespace SCM3.FormBuilder.UI.Designer
@using SCM3.FormBuilder.Core.Models
@using SCM3.FormBuilder.Data
@using SCM3.FormBuilder.UI.Renderer
@using Microsoft.AspNetCore.Components.Web

@if (_version is null)
{
    <TelerikLoader Visible="true" Type="@LoaderType.InfiniteSpinner" />
}
else
{
<div class="fb-designer">
    <div class="fb-palette">
        <p class="fb-palette-title">Fields</p>
        @foreach (var type in Enum.GetValues<FieldType>())
        {
            <div class="fb-palette-item"
                 draggable="true"
                 @ondragstart="e => OnPaletteDragStart(type, e)"
                 @onclick="() => AddFieldToActiveSection(type)">
                @type
            </div>
        }
        <p class="fb-hint">Click to add, or drag to canvas.</p>
    </div>

    <div class="fb-canvas">
        <div class="fb-canvas-header">
            <div>
                <p class="fb-form-title">@ToolType / @FormKey</p>
                <div class="fb-form-subtitle">
                    <span style="font-size:0.85em;color:#666">
                        @(_version.IsPublished ? "Published" : "Draft") · v@(_version.VersionNumber)
                        @if (_availableVersions?.Count > 1)
                        {
                            <span> · </span>
                            <TelerikDropDownList Data="@VersionItems"
                                                 Value="@_version.VersionNumber"
                                                 ValueChanged="@((int v) => OnVersionChange(v))"
                                                 TextField="@nameof(VersionItem.Label)"
                                                 ValueField="@nameof(VersionItem.Number)"
                                                 Width="180px" />
                        }
                    </span>
                </div>
            </div>
            <div class="fb-canvas-actions">
                <TelerikButton FillMode="@ThemeConstants.Button.FillMode.Outline"
                               OnClick="@(() => _showPreview = !_showPreview)">
                    @(_showPreview ? "← Design" : "Preview →")
                </TelerikButton>
                @if (_version.IsPublished)
                {
                    <span style="font-size:0.85em;color:#388e3c;font-weight:600;padding:0 8px">✓ Published</span>
                    <TelerikButton ThemeColor="@ThemeConstants.Button.ThemeColor.Primary"
                                   OnClick="@StartNewVersion">New Version</TelerikButton>
                }
                else
                {
                    <TelerikButton OnClick="@SaveDraft">Save Draft</TelerikButton>
                    <TelerikButton ThemeColor="@ThemeConstants.Button.ThemeColor.Primary"
                                   OnClick="@Publish">Publish</TelerikButton>
                }
            </div>
        </div>

        @if (_showPreview)
        {
            <div style="padding:16px">
                <FormRenderer ToolType="@ToolType" FormKey="@FormKey" RecordPrimaryKey="" ReadOnly="false" />
            </div>
        }
        else
        {
            @foreach (var sec in _version.Sections.OrderBy(s => s.Order))
            {
                var sectionId = sec.SectionId;
                var sectionObj = sec;
                var isActive = sec == _activeSection;
                var isDragOver = _dragOverSectionId == sec.SectionId;
                <div class="fb-section-editor @(isActive ? "fb-section-active" : "") @(isDragOver ? "fb-section-dragover" : "")"
                     @onclick="() => _activeSection = sec"
                     @ondragover="e => OnSectionDragOver(sectionId, e)"
                     @ondragleave="() => OnSectionDragLeave()"
                     @ondrop="e => OnSectionDrop(sectionObj, e)">

                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px" @onclick:stopPropagation="true">
                        <TelerikTextBox @bind-Value="sec.Title"
                                        PlaceHolder="Section title"
                                        Width="100%" />
                        <span style="font-size:0.8em;color:#999;white-space:nowrap">@(isActive ? "active" : "")</span>
                    </div>

                    @foreach (var field in sec.Fields.OrderBy(f => f.GridRow).ThenBy(f => f.GridColumn))
                    {
                        var f = field;
                        <div class="fb-field-card @(field == _selectedField ? "fb-field-card-selected" : "")"
                             @onclick="() => SelectField(field)" @onclick:stopPropagation="true">
                            <div class="fb-field-card-row">
                                <span class="fb-field-card-label">@field.Label</span>
                                <div style="display:flex;gap:2px" @onclick:stopPropagation="true">
                                    <TelerikButton FillMode="@ThemeConstants.Button.FillMode.Flat"
                                                   Size="@ThemeConstants.Button.Size.Small"
                                                   OnClick="@(() => MoveField(sectionObj, f, -1))">↑</TelerikButton>
                                    <TelerikButton FillMode="@ThemeConstants.Button.FillMode.Flat"
                                                   Size="@ThemeConstants.Button.Size.Small"
                                                   OnClick="@(() => MoveField(sectionObj, f, 1))">↓</TelerikButton>
                                    <TelerikButton FillMode="@ThemeConstants.Button.FillMode.Flat"
                                                   Size="@ThemeConstants.Button.Size.Small"
                                                   OnClick="@(() => DuplicateField(sectionObj, f))">⧉</TelerikButton>
                                    @if (field.ConditionalRules?.Count > 0)
                                    {
                                        <span class="fb-field-badge" title="Has conditional rules">@field.ConditionalRules.Count rule(s)</span>
                                    }
                                </div>
                            </div>
                            <p class="fb-field-card-meta">
                                @field.Type
                                @(field.Validation?.Required == true ? " · required" : "")
                                · span @field.GridSpan/12
                            </p>
                        </div>
                    }
                </div>
            }

            <TelerikButton FillMode="@ThemeConstants.Button.FillMode.Outline"
                           OnClick="@AddSection"
                           Class="w-100">Add section</TelerikButton>
        }
    </div>

    <div class="fb-properties">
        <p class="fb-palette-title">Field properties</p>
        @if (_selectedField is null)
        {
            <p class="fb-hint">Select a field to edit its properties.</p>
        }
        else
        {
            <label class="fb-prop-label">Label</label>
            <TelerikTextBox @bind-Value="@_selectedField.Label" Width="100%" />

            <label class="fb-prop-label">Grid column (1-12)</label>
            <TelerikNumericTextBox @bind-Value="@_selectedField.GridColumn"
                                   Min="1" Max="12" Decimals="0" Width="100%" />

            <label class="fb-prop-label">Grid span</label>
            <TelerikNumericTextBox @bind-Value="@_selectedField.GridSpan"
                                   Min="1" Max="12" Decimals="0" Width="100%" />

            <label class="fb-prop-label">Grid row</label>
            <TelerikNumericTextBox @bind-Value="@_selectedField.GridRow"
                                   Min="1" Decimals="0" Width="100%" />

            @if (_selectedField.Type is FieldType.Dropdown or FieldType.ComboBox or FieldType.MultiSelect)
            {
                <label class="fb-prop-label">Options (comma separated)</label>
                <TelerikTextBox Value="@OptionsAsCsv"
                                ValueChanged="@((string v) => UpdateSelectedOptions(v))"
                                Width="100%" />
            }

            @if (_selectedField.Type == FieldType.ComboBox)
            {
                <label class="fb-prop-checkbox">
                    <TelerikCheckBox @bind-Value="@_selectedField.AllowCustomValue" />
                    Allow custom value
                </label>
            }

            <label class="fb-prop-checkbox">
                <TelerikCheckBox Value="@(_selectedField.Validation?.Required ?? false)"
                                 ValueChanged="@((bool v) => { _selectedField.Validation ??= new ValidationRule(); _selectedField.Validation.Required = v; })" />
                Required
            </label>

            @if (_selectedField.Type is FieldType.Text or FieldType.TextArea or FieldType.ComboBox
                                          or FieldType.Dropdown or FieldType.MultiSelect)
            {
                <label class="fb-prop-label">Placeholder</label>
                <TelerikTextBox @bind-Value="@_selectedField.Placeholder" Width="100%" />
            }

            <label class="fb-prop-label">Default value</label>
            <TelerikTextBox @bind-Value="@_selectedField.DefaultValue" Width="100%" />

            @if (_selectedField.Type is FieldType.Text or FieldType.ComboBox or FieldType.TextArea)
            {
                <label class="fb-prop-label">Max length</label>
                <TelerikNumericTextBox Value="@((int?)(_selectedField.Validation?.MaxLength))"
                                       ValueChanged="@((int? v) => { _selectedField.Validation ??= new ValidationRule(); _selectedField.Validation.MaxLength = v; })"
                                       Min="1" Decimals="0" Width="100%" />

                <label class="fb-prop-label">Regex pattern</label>
                <TelerikTextBox Value="@(_selectedField.Validation?.RegexPattern)"
                                ValueChanged="@((string? v) => { _selectedField.Validation ??= new ValidationRule(); _selectedField.Validation.RegexPattern = v; })"
                                PlaceHolder="e.g. ^\d{4}$"
                                Width="100%" />
            }

            @if (_selectedField.Type == FieldType.Number)
            {
                <label class="fb-prop-label">Decimal places</label>
                <TelerikNumericTextBox @bind-Value="@_selectedField.Decimals"
                                       Min="0" Max="10" Decimals="0" Width="100%" />

                <label class="fb-prop-label">Min</label>
                <TelerikNumericTextBox Value="@(_selectedField.Validation?.Min)"
                                       ValueChanged="@((decimal? v) => { _selectedField.Validation ??= new ValidationRule(); _selectedField.Validation.Min = v; })"
                                       Width="100%" />

                <label class="fb-prop-label">Max</label>
                <TelerikNumericTextBox Value="@(_selectedField.Validation?.Max)"
                                       ValueChanged="@((decimal? v) => { _selectedField.Validation ??= new ValidationRule(); _selectedField.Validation.Max = v; })"
                                       Width="100%" />
            }

            <div class="fb-prop-divider">
                <p class="fb-prop-label">Conditional rules</p>
                @if (_selectedField.ConditionalRules is { Count: > 0 })
                {
                    @foreach (var rule in _selectedField.ConditionalRules)
                    {
                        <div class="fb-rule-chip">
                            @($"{rule.Effect} when {rule.SourceFieldId} {rule.Operator} \"{rule.Value}\"")
                            <TelerikButton FillMode="@ThemeConstants.Button.FillMode.Flat"
                                           ThemeColor="@ThemeConstants.Button.ThemeColor.Error"
                                           Size="@ThemeConstants.Button.Size.Small"
                                           OnClick="@(() => RemoveRule(rule))">✕</TelerikButton>
                        </div>
                    }
                }
                <TelerikButton FillMode="@ThemeConstants.Button.FillMode.Outline"
                               OnClick="@(() => _showRuleBuilder = true)"
                               Class="w-100">Add conditional rule</TelerikButton>
            </div>

            <TelerikButton ThemeColor="@ThemeConstants.Button.ThemeColor.Error"
                           OnClick="@RemoveSelectedField"
                           Class="w-100">Delete field</TelerikButton>
        }
    </div>
</div>
}

<TelerikWindow @bind-Visible="@_showRuleBuilder" Modal="true" Width="480px">
    <WindowTitle>
        Add conditional rule@(_selectedField is not null ? $" for {_selectedField.Label}" : "")
    </WindowTitle>
    <WindowContent>
        @if (_selectedField is not null)
        {
            <div style="display:flex;flex-direction:column;gap:12px">
                <div>
                    <label class="fb-prop-label">When field</label>
                    <TelerikDropDownList Data="@AllFieldsExcept(_selectedField).ToList()"
                                         @bind-Value="@_ruleSourceFieldId"
                                         TextField="@nameof(Field.Label)"
                                         ValueField="@nameof(Field.FieldId)"
                                         Width="100%" />
                </div>
                <div>
                    <label class="fb-prop-label">Operator</label>
                    <TelerikDropDownList Data="@_operators"
                                         @bind-Value="@_ruleOperator"
                                         Width="100%" />
                </div>
                <div>
                    <label class="fb-prop-label">Value</label>
                    <TelerikTextBox @bind-Value="@_ruleValue" Width="100%" />
                </div>
                <div>
                    <label class="fb-prop-label">Effect on @_selectedField.Label</label>
                    <TelerikDropDownList Data="@_effects"
                                         @bind-Value="@_ruleEffect"
                                         Width="100%" />
                </div>
                <div style="display:flex;gap:8px;margin-top:4px">
                    <TelerikButton OnClick="@(() => _showRuleBuilder = false)">Cancel</TelerikButton>
                    <TelerikButton ThemeColor="@ThemeConstants.Button.ThemeColor.Primary"
                                   OnClick="@SaveRule">Add rule</TelerikButton>
                </div>
            </div>
        }
    </WindowContent>
</TelerikWindow>

@code {
    [Parameter, EditorRequired] public string ToolType { get; set; } = "";
    [Parameter, EditorRequired] public string FormKey { get; set; } = "";
    [Parameter] public EventCallback<FormVersion> OnPublished { get; set; }

    [Inject] private IFormRepository Repository { get; set; } = null!;

    private FormVersion _version = null!;
    private Field? _selectedField;
    private Section? _activeSection;
    private bool _showRuleBuilder;
    private string _ruleSourceFieldId = "";
    private string _ruleOperator = "equals";
    private string _ruleValue = "";
    private ConditionalEffect _ruleEffect = ConditionalEffect.Show;

    private List<(int VersionNumber, bool IsPublished)>? _availableVersions;
    private string _loadedToolType = "";
    private string _loadedFormKey = "";

    private FieldType? _draggedFieldType;
    private string _dragOverSectionId = "";
    private bool _showPreview;

    private static readonly List<string> _operators = new() { "equals", "notEquals", "contains" };
    private static readonly List<ConditionalEffect> _effects = Enum.GetValues<ConditionalEffect>().ToList();

    private record VersionItem(int Number, string Label);

    private List<VersionItem>? VersionItems =>
        _availableVersions?
            .OrderByDescending(v => v.VersionNumber)
            .Select(v => new VersionItem(v.VersionNumber, $"v{v.VersionNumber}{(v.IsPublished ? " (published)" : " (draft)")}"))
            .ToList();

    private string OptionsAsCsv =>
        string.Join(",", _selectedField?.Options?.Select(o => o.Label) ?? Enumerable.Empty<string>());

    protected override async Task OnInitializedAsync()
    {
        _loadedToolType = ToolType;
        _loadedFormKey = FormKey;
        await LoadForm();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ToolType != _loadedToolType || FormKey != _loadedFormKey)
        {
            _loadedToolType = ToolType;
            _loadedFormKey = FormKey;
            _selectedField = null;
            _activeSection = null;
            await LoadForm();
        }
        await base.OnParametersSetAsync();
    }

    private async Task LoadForm()
    {
        _availableVersions = await Repository.ListVersions(ToolType, FormKey);

        var existing = await Repository.GetVersion(ToolType, FormKey);

        if (existing is not null)
        {
            _version = existing;
        }
        else
        {
            _version = new FormVersion
            {
                FormVersionId = Guid.NewGuid(),
                FormId = Guid.NewGuid(),
                ToolType = ToolType,
                FormKey = FormKey,
                VersionNumber = 1,
                IsPublished = false,
                Sections = new List<Section>
                {
                    new Section { SectionId = Guid.NewGuid().ToString(), Title = "General", Order = 1 }
                }
            };
        }

        _activeSection = _version.Sections.OrderBy(s => s.Order).FirstOrDefault();
    }

    private void StartNewVersion()
    {
        var nextNumber = _version.VersionNumber + 1;
        _version = new FormVersion
        {
            FormVersionId = Guid.NewGuid(),
            FormId = _version.FormId,
            ToolType = ToolType,
            FormKey = FormKey,
            VersionNumber = nextNumber,
            IsPublished = false,
            Sections = _version.Sections
                .Select(s => new Section
                {
                    SectionId = Guid.NewGuid().ToString(),
                    Title = s.Title,
                    Order = s.Order,
                    Fields = s.Fields.Select(f => new Field
                    {
                        FieldId    = Guid.NewGuid().ToString(),
                        Type       = f.Type,
                        Label      = f.Label,
                        GridRow    = f.GridRow,
                        GridColumn = f.GridColumn,
                        GridSpan   = f.GridSpan,
                        Options    = f.Options?.Select(o => new FieldOption { Value = o.Value, Label = o.Label }).ToList(),
                        Validation = f.Validation,
                        ConditionalRules = f.ConditionalRules
                    }).ToList()
                }).ToList()
        };
        _selectedField = null;
        _activeSection = _version.Sections.OrderBy(s => s.Order).FirstOrDefault();
    }

    private async Task OnVersionChange(int versionNumber)
    {
        var selected = await Repository.GetVersion(ToolType, FormKey, versionNumber);
        if (selected != null)
        {
            _version = selected;
            _selectedField = null;
            _activeSection = _version.Sections.OrderBy(s => s.Order).FirstOrDefault();
        }
    }

    private void SelectField(Field field) => _selectedField = field;

    private void AddSection()
    {
        var newSection = new Section
        {
            SectionId = Guid.NewGuid().ToString(),
            Title = $"Section {_version.Sections.Count + 1}",
            Order = _version.Sections.Count + 1
        };
        _version.Sections.Add(newSection);
        _activeSection = newSection;
    }

    private void AddFieldToActiveSection(FieldType type)
    {
        if (_activeSection is null) AddSection();

        var section = _activeSection!;
        var nextRow = section.Fields.Count == 0 ? 1 : section.Fields.Max(f => f.GridRow) + 1;

        var field = new Field
        {
            FieldId = Guid.NewGuid().ToString(),
            Type = type,
            Label = $"New {type} field",
            GridRow = nextRow,
            GridColumn = 1,
            GridSpan = 12,
            Options = type is FieldType.Dropdown or FieldType.ComboBox or FieldType.MultiSelect
                ? new List<FieldOption>()
                : null
        };

        section.Fields.Add(field);
        _selectedField = field;
    }

    private void OnPaletteDragStart(FieldType fieldType, DragEventArgs e)
    {
        _draggedFieldType = fieldType;
        if (e.DataTransfer != null)
            e.DataTransfer.EffectAllowed = "copy";
    }

    private void OnSectionDragOver(string sectionId, DragEventArgs e)
    {
        _dragOverSectionId = sectionId;
        if (e.DataTransfer != null)
            e.DataTransfer.DropEffect = "copy";
    }

    private void OnSectionDragLeave() => _dragOverSectionId = "";

    private void OnSectionDrop(Section section, DragEventArgs e)
    {
        _dragOverSectionId = "";
        if (_draggedFieldType.HasValue)
        {
            _activeSection = section;
            AddFieldToActiveSection(_draggedFieldType.Value);
            _draggedFieldType = null;
        }
    }

    private void UpdateSelectedOptions(string? csv)
    {
        if (_selectedField is null) return;
        var labels = (csv ?? "").Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
        _selectedField.Options = labels
            .Select(l => new FieldOption { Label = l, Value = l.ToLowerInvariant().Replace(" ", "-") })
            .ToList();
    }

    private void RemoveSelectedField()
    {
        if (_selectedField is null) return;
        foreach (var section in _version.Sections)
            section.Fields.Remove(_selectedField);
        _selectedField = null;
    }

    private void MoveField(Section section, Field field, int direction)
    {
        var ordered = section.Fields.OrderBy(f => f.GridRow).ToList();
        var idx = ordered.IndexOf(field);
        var swapIdx = idx + direction;
        if (swapIdx < 0 || swapIdx >= ordered.Count) return;

        var other = ordered[swapIdx];
        (field.GridRow, other.GridRow) = (other.GridRow, field.GridRow);
    }

    private void DuplicateField(Section section, Field field)
    {
        var maxRow = section.Fields.Count == 0 ? 1 : section.Fields.Max(f => f.GridRow) + 1;
        var copy = new Field
        {
            FieldId    = Guid.NewGuid().ToString(),
            Type       = field.Type,
            Label      = field.Label + " (copy)",
            GridRow    = maxRow,
            GridColumn = field.GridColumn,
            GridSpan   = field.GridSpan,
            Placeholder  = field.Placeholder,
            DefaultValue = field.DefaultValue,
            Decimals     = field.Decimals,
            AllowCustomValue = field.AllowCustomValue,
            Options    = field.Options?.Select(o => new FieldOption { Value = o.Value, Label = o.Label }).ToList(),
            Validation = field.Validation is null ? null : new ValidationRule
            {
                Required     = field.Validation.Required,
                MaxLength    = field.Validation.MaxLength,
                RegexPattern = field.Validation.RegexPattern,
                Min          = field.Validation.Min,
                Max          = field.Validation.Max
            },
            ConditionalRules = field.ConditionalRules?.Select(r => new ConditionalRule
            {
                SourceFieldId = r.SourceFieldId,
                Operator      = r.Operator,
                Value         = r.Value,
                Effect        = r.Effect
            }).ToList()
        };
        section.Fields.Add(copy);
        _selectedField = copy;
    }

    private IEnumerable<Field> AllFieldsExcept(Field exclude) =>
        _version.Sections.SelectMany(s => s.Fields).Where(f => f.FieldId != exclude.FieldId);

    private void SaveRule()
    {
        if (_selectedField is null || string.IsNullOrWhiteSpace(_ruleSourceFieldId)) return;

        _selectedField.ConditionalRules ??= new List<ConditionalRule>();
        _selectedField.ConditionalRules.Add(new ConditionalRule
        {
            SourceFieldId = _ruleSourceFieldId,
            Operator = _ruleOperator,
            Value = _ruleValue,
            Effect = _ruleEffect
        });

        _showRuleBuilder = false;
    }

    private void RemoveRule(ConditionalRule rule) =>
        _selectedField?.ConditionalRules?.Remove(rule);

    private async Task SaveDraft() =>
        await Repository.SaveVersion(_version);

    private async Task Publish()
    {
        _version.IsPublished = true;
        _version.PublishedDate = DateTime.UtcNow;
        await Repository.SaveVersion(_version);
        await OnPublished.InvokeAsync(_version);
    }
}
