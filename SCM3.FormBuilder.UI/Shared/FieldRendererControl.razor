@namespace SCM3.FormBuilder.UI.Shared
@using SCM3.FormBuilder.Core.Models
@using SCM3.FormBuilder.Core.Evaluation

<div style="grid-column: @(Field.GridColumn) / span @(Field.GridSpan); grid-row: @(Field.GridRow);">
    @if (RenderState.Visible)
    {
        <label class="fb-label">
            @Field.Label
            @if (Field.Validation?.Required == true)
            {
                <span class="fb-required">*</span>
            }
        </label>

        @switch (Field.Type)
        {
            case FieldType.Text:
                <TelerikTextBox Value="@CurrentValue"
                                ValueChanged="@((string? v) => NotifyString(v))"
                                Enabled="@RenderState.Enabled"
                                ReadOnly="@RenderState.ReadOnly"
                                PlaceHolder="@(Field.Placeholder ?? "")"
                                MaxLength="@(Field.Validation?.MaxLength ?? int.MaxValue)"
                                Width="100%" />
                break;

            case FieldType.Number:
                <TelerikNumericTextBox T="decimal?"
                                       @bind-Value:get="_numericValue"
                                       @bind-Value:set="OnNumericSet"
                                       Enabled="@RenderState.Enabled"
                                       Min="@(Field.Validation?.Min)"
                                       Max="@(Field.Validation?.Max)"
                                       Decimals="@Field.Decimals"
                                       Width="100%" />
                break;

            case FieldType.Date:
                <TelerikDatePicker Value="@CurrentDate"
                                   ValueChanged="@((DateTime? v) => NotifyString(v?.ToString("yyyy-MM-dd")))"
                                   Enabled="@RenderState.Enabled"
                                   Width="100%" />
                break;

            case FieldType.DateTimePicker:
                <TelerikDateTimePicker Value="@CurrentDate"
                                       ValueChanged="@((DateTime? v) => NotifyString(v?.ToString("yyyy-MM-ddTHH:mm")))"
                                       Enabled="@RenderState.Enabled"
                                       Width="100%" />
                break;

            case FieldType.Dropdown:
                <TelerikDropDownList Data="@(Field.Options ?? new())"
                                     Value="@CurrentValue"
                                     ValueChanged="@((string? v) => NotifyString(v))"
                                     TextField="@nameof(FieldOption.Label)"
                                     ValueField="@nameof(FieldOption.Value)"
                                     DefaultText="@(Field.Placeholder ?? "-- select --")"
                                     Enabled="@RenderState.Enabled"
                                     Width="100%" />
                break;

            case FieldType.ComboBox:
                <TelerikComboBox Data="@(Field.Options ?? new())"
                                 Value="@CurrentValue"
                                 ValueChanged="@((string? v) => NotifyString(v))"
                                 TextField="@nameof(FieldOption.Label)"
                                 ValueField="@nameof(FieldOption.Value)"
                                 AllowCustom="@Field.AllowCustomValue"
                                 Placeholder="@(Field.Placeholder ?? "-- select or type --")"
                                 Enabled="@RenderState.Enabled"
                                 Width="100%" />
                break;

            case FieldType.Checkbox:
                <TelerikCheckBox Value="@(CurrentValue == "true")"
                                 ValueChanged="@((bool v) => NotifyString(v ? "true" : "false"))"
                                 Enabled="@RenderState.Enabled" />
                break;

            case FieldType.TextArea:
                <TelerikTextArea Value="@(CurrentValue ?? "")"
                                 ValueChanged="@((string v) => NotifyString(v))"
                                 Enabled="@RenderState.Enabled"
                                 ReadOnly="@RenderState.ReadOnly"
                                 PlaceHolder="@(Field.Placeholder ?? "")"
                                 MaxLength="@(Field.Validation?.MaxLength ?? int.MaxValue)"
                                 Width="100%"
                                 AutoSize="true" />
                break;

            case FieldType.MultiSelect:
                <TelerikMultiSelect Data="@(Field.Options ?? new())"
                                    Value="@SelectedMultiValues"
                                    ValueChanged="@((List<string> v) => NotifyMulti(v))"
                                    TextField="@nameof(FieldOption.Label)"
                                    ValueField="@nameof(FieldOption.Value)"
                                    Placeholder="@(Field.Placeholder ?? "-- select --")"
                                    Enabled="@RenderState.Enabled"
                                    Width="100%" />
                break;

            case FieldType.RichText:
                <TelerikEditor Value="@(CurrentValue ?? "")"
                               ValueChanged="@((string v) => NotifyString(v))"
                               Height="200px" />
                break;
        }

        @if (ShowValidationError)
        {
            <p class="fb-error">@ValidationErrorMessage</p>
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public Field Field { get; set; } = null!;
    [Parameter, EditorRequired] public FieldRenderState RenderState { get; set; } = null!;
    [Parameter, EditorRequired] public Dictionary<string, object?> Values { get; set; } = null!;
    [Parameter] public EventCallback<(string FieldId, object? Value)> OnFieldValueChanged { get; set; }
    [Parameter] public bool ShowValidationError { get; set; }
    [Parameter] public string? ValidationErrorMessage { get; set; }

    private decimal? _numericValue;
    private string? _lastKnownFieldId;

    protected override void OnParametersSet()
    {
        if (Field.Type == FieldType.Number && _lastKnownFieldId != Field.FieldId)
        {
            _lastKnownFieldId = Field.FieldId;
            var raw = Values.TryGetValue(Field.FieldId, out var v) ? v?.ToString() : Field.DefaultValue;
            _numericValue = decimal.TryParse(raw, System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var n) ? n : null;
        }
    }

    private async Task OnNumericSet(decimal? v)
    {
        _numericValue = v;
        await NotifyString(v?.ToString(System.Globalization.CultureInfo.InvariantCulture));
    }

    private string? CurrentValue
    {
        get
        {
            if (Values.TryGetValue(Field.FieldId, out var v)) return v?.ToString();
            return Field.DefaultValue;
        }
    }

    private DateTime? CurrentDate =>
        DateTime.TryParse(CurrentValue, out var d) ? d : (DateTime?)null;

    private List<string> SelectedMultiValues
    {
        get
        {
            if (Values.TryGetValue(Field.FieldId, out var v) && v is string s)
                return s.Split(',', StringSplitOptions.RemoveEmptyEntries).ToList();
            return new List<string>();
        }
    }

    private async Task NotifyString(string? value) =>
        await OnFieldValueChanged.InvokeAsync((Field.FieldId, (object?)value));

    private async Task NotifyMulti(List<string> values) =>
        await OnFieldValueChanged.InvokeAsync((Field.FieldId, (object?)string.Join(",", values)));
}
