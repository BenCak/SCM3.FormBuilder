@namespace SCM3.FormBuilder.UI.Shared
@using SCM3.FormBuilder.Core.Models
@using SCM3.FormBuilder.Core.Evaluation

<div style="grid-column: @(Field.GridColumn) / span @(Field.GridSpan); grid-row: @(Field.GridRow);">
    @if (RenderState.Visible)
    {
        <label class="fb-label">
            @Field.Label
            @if (Field.Validation?.Required == true)
            {
                <span class="fb-required">*</span>
            }
        </label>

        @switch (Field.Type)
        {
            case FieldType.Text:
                <input type="text"
                       value="@CurrentValue"
                       disabled="@(!RenderState.Enabled)"
                       readonly="@RenderState.ReadOnly"
                       maxlength="@Field.Validation?.MaxLength"
                       @onchange="OnValueChanged"
                       class="fb-input" />
                break;

            case FieldType.Number:
                <input type="number"
                       value="@CurrentValue"
                       disabled="@(!RenderState.Enabled)"
                       readonly="@RenderState.ReadOnly"
                       min="@Field.Validation?.Min"
                       max="@Field.Validation?.Max"
                       @onchange="OnValueChanged"
                       class="fb-input" />
                break;

            case FieldType.Date:
            case FieldType.DateTimePicker:
                <input type="@(Field.Type == FieldType.Date ? "date" : "datetime-local")"
                       value="@CurrentValue"
                       disabled="@(!RenderState.Enabled)"
                       readonly="@RenderState.ReadOnly"
                       @onchange="OnValueChanged"
                       class="fb-input" />
                break;

            case FieldType.Dropdown:
                <select value="@CurrentValue"
                        disabled="@(!RenderState.Enabled)"
                        @onchange="OnValueChanged"
                        class="fb-input">
                    <option value="">-- select --</option>
                    @if (Field.Options is not null)
                    {
                        @foreach (var opt in Field.Options)
                        {
                            <option value="@opt.Value">@opt.Label</option>
                        }
                    }
                </select>
                break;

            case FieldType.ComboBox:
                <input type="text"
                       value="@CurrentValue"
                       disabled="@(!RenderState.Enabled)"
                       readonly="@RenderState.ReadOnly"
                       placeholder="-- select or type --"
                       maxlength="@Field.Validation?.MaxLength"
                       @onchange="OnValueChanged"
                       class="fb-input" />
                break;

            case FieldType.Checkbox:
                <input type="checkbox"
                       checked="@(CurrentValue == "true")"
                       disabled="@(!RenderState.Enabled)"
                       @onchange="OnCheckboxChanged"
                       class="fb-checkbox" />
                break;

            case FieldType.TextArea:
                <textarea disabled="@(!RenderState.Enabled)"
                          readonly="@RenderState.ReadOnly"
                          maxlength="@Field.Validation?.MaxLength"
                          @onchange="OnValueChanged"
                          class="fb-input fb-textarea">@CurrentValue</textarea>
                break;

            case FieldType.MultiSelect:
                <select multiple="multiple"
                        disabled="@(!RenderState.Enabled)"
                        @onchange="OnMultiSelectChanged"
                        class="fb-input">
                    @if (Field.Options is not null)
                    {
                        @foreach (var opt in Field.Options)
                        {
                            var isSelected = SelectedMultiValues?.Contains(opt.Value) ?? false;
                            <option value="@opt.Value" selected="@isSelected">@opt.Label</option>
                        }
                    }
                </select>
                break;

            case FieldType.RichText:
                <textarea disabled="@(!RenderState.Enabled)"
                          readonly="@RenderState.ReadOnly"
                          @onchange="OnValueChanged"
                          class="fb-input fb-textarea">@CurrentValue</textarea>
                break;
        }

        @if (ShowValidationError)
        {
            <p class="fb-error">@ValidationErrorMessage</p>
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public Field Field { get; set; } = null!;
    [Parameter, EditorRequired] public FieldRenderState RenderState { get; set; } = null!;
    [Parameter, EditorRequired] public Dictionary<string, object?> Values { get; set; } = null!;
    [Parameter] public EventCallback<(string FieldId, object? Value)> OnFieldValueChanged { get; set; }
    [Parameter] public bool ShowValidationError { get; set; }
    [Parameter] public string? ValidationErrorMessage { get; set; }

    private string? CurrentValue
    {
        get => Values.TryGetValue(Field.FieldId, out var v) ? v?.ToString() : null;
        set { if (value is not null) Values[Field.FieldId] = value; }
    }

    private List<string>? SelectedMultiValues
    {
        get
        {
            if (Values.TryGetValue(Field.FieldId, out var v) && v is string strVal)
            {
                return strVal.Split(',').Where(s => !string.IsNullOrEmpty(s)).ToList();
            }
            return new List<string>();
        }
        set
        {
            if (value is not null)
            {
                Values[Field.FieldId] = string.Join(",", value);
            }
        }
    }

    private async Task OnValueChanged(ChangeEventArgs e)
    {
        await OnFieldValueChanged.InvokeAsync((Field.FieldId, e.Value));
    }

    private async Task OnCheckboxChanged(ChangeEventArgs e)
    {
        await OnFieldValueChanged.InvokeAsync((Field.FieldId, e.Value));
    }

    private async Task OnMultiSelectChanged(ChangeEventArgs e)
    {
        // For HTML multi-select, treat as single value
        await OnFieldValueChanged.InvokeAsync((Field.FieldId, e.Value));
    }
}
