@namespace SCM3.FormBuilder.UI.Renderer
@using SCM3.FormBuilder.Core.Models
@using SCM3.FormBuilder.Core.Evaluation
@using SCM3.FormBuilder.Data
@using SCM3.FormBuilder.UI.Shared

@if (_loading)
{
    <TelerikLoader Visible="true" Type="@LoaderType.InfiniteSpinner" />
}
else if (_version is null)
{
    <p class="fb-error">No published form found for @ToolType / @FormKey.</p>
}
else
{
    <div class="fb-form">
        @if (!string.IsNullOrWhiteSpace(_artifactId))
        {
            <div class="fb-artifact-selector">
                <label>Artifact ID:</label>
                <span style="padding:8px 12px;border:1px solid #ddd;border-radius:4px;background:#f5f5f5;display:inline-block;min-width:200px;font-family:monospace">@_artifactId</span>
                @if (_version is not null)
                {
                    <span style="font-size:0.8em;color:#888;margin-left:8px">v@(_version.VersionNumber)</span>
                }
            </div>
        }

        @foreach (var sectionItem in _version.Sections.OrderBy(s => s.Order))
        {
            <div class="fb-section">
                <h3 class="fb-section-title">@sectionItem.Title</h3>
                <div class="fb-grid">
                    @foreach (var field in sectionItem.Fields)
                    {
                        var state = _renderStates.TryGetValue(field.FieldId, out var s)
                            ? s
                            : new FieldRenderState(true, true, false);

                        var effectiveState = ReadOnly
                            ? new FieldRenderState(state.Visible, false, true)
                            : state;

                        var hasError = _fieldErrors.TryGetValue(field.FieldId, out var errMsg);

                        <FieldRendererControl Field="field"
                                              RenderState="effectiveState"
                                              Values="_values"
                                              OnFieldValueChanged="HandleFieldValueChanged"
                                              ShowValidationError="hasError"
                                              ValidationErrorMessage="@errMsg" />
                    }
                </div>
            </div>
        }

        @if (!ReadOnly)
        {
            <div class="fb-actions">
                <TelerikButton OnClick="@HandleCancel">Cancel</TelerikButton>
                <TelerikButton ThemeColor="@ThemeConstants.Button.ThemeColor.Primary"
                               OnClick="@HandleSave"
                               Enabled="@(!_saving && !string.IsNullOrWhiteSpace(_artifactId))">
                    @if (_saving) { <span>Saving...</span> }
                    else if (_saved) { <span>Saved ✓</span> }
                    else { <span>Save</span> }
                </TelerikButton>
            </div>

            @if (_validationErrors.Count > 0)
            {
                <div class="fb-validation-summary">
                    @foreach (var err in _validationErrors)
                    {
                        <p class="fb-error">@err</p>
                    }
                </div>
            }
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public string ToolType { get; set; } = "";
    [Parameter, EditorRequired] public string FormKey { get; set; } = "";
    [Parameter] public string RecordPrimaryKey { get; set; } = "";
    [Parameter] public bool ReadOnly { get; set; }

    // Fired after a successful save, with the raw values the host can do
    // its own cross-cutting validation against if it needs to.
    [Parameter] public EventCallback<Dictionary<string, object?>> OnSaved { get; set; }
    [Parameter] public EventCallback<Dictionary<string, object?>> OnSavedByLabel { get; set; }
    [Parameter] public EventCallback OnCancelled { get; set; }

    [Inject] private IFormRepository Repository { get; set; } = null!;

    private FormVersion? _version;
    private Dictionary<string, object?> _values = new();
    private Dictionary<string, FieldRenderState> _renderStates = new();
    private readonly ConditionalRuleEvaluator _evaluator = new();
    private readonly List<string> _validationErrors = new();
    private Dictionary<string, string> _fieldErrors = new();
    private string _artifactId = "";
    private string _loadedFormKey = "";
    private string _loadedToolType = "";
    private Guid? _existingSubmissionId;
    private bool _loading = true;
    private bool _saving;
    private bool _saved;

    protected override async Task OnInitializedAsync()
    {
        _artifactId = RecordPrimaryKey ?? "";
        _loadedFormKey = FormKey;
        _loadedToolType = ToolType;
        await LoadForm();
    }

    protected override async Task OnParametersSetAsync()
    {
        var formChanged = FormKey != _loadedFormKey || ToolType != _loadedToolType;
        var artifactChanged = RecordPrimaryKey != _artifactId;

        if (formChanged || artifactChanged)
        {
            _artifactId = RecordPrimaryKey ?? "";
            _values.Clear();
            _validationErrors.Clear();
            _renderStates.Clear();
            _existingSubmissionId = null;
            _saved = false;

            if (formChanged)
            {
                _loadedFormKey = FormKey;
                _loadedToolType = ToolType;
                await LoadForm();
            }
            else
            {
                await LoadExistingSubmission();
                StateHasChanged();
            }
        }

        await base.OnParametersSetAsync();
    }

    private async Task LoadForm()
    {
        _loading = true;
        await LoadSubmissionAndForm();
        _loading = false;
    }

    private async Task LoadExistingSubmission()
    {
        await LoadSubmissionAndForm();
    }

    // Loads the submission first (if any), then loads the form version that
    // was used for that submission. Falls back to latest if no submission exists.
    private async Task LoadSubmissionAndForm()
    {
        _existingSubmissionId = null;
        _values.Clear();

        int? versionToLoad = null;

        if (!string.IsNullOrWhiteSpace(_artifactId))
        {
            var submissions = await Repository.GetSubmissions(ToolType, FormKey, _artifactId);
            var latest = submissions.FirstOrDefault();
            if (latest is not null)
            {
                versionToLoad = latest.FormVersionNumber;
                _existingSubmissionId = latest.SubmissionId;
                foreach (var kvp in latest.Values)
                    _values[kvp.Key] = ExtractJsonValue(kvp.Value.Value);
            }
        }

        _version = await Repository.GetVersion(ToolType, FormKey, versionToLoad);
        RecomputeRenderStates();
    }

    private static object? ExtractJsonValue(object? raw)
    {
        if (raw is System.Text.Json.JsonElement el)
        {
            return el.ValueKind switch
            {
                System.Text.Json.JsonValueKind.True   => "true",
                System.Text.Json.JsonValueKind.False  => "false",
                System.Text.Json.JsonValueKind.Null   => null,
                System.Text.Json.JsonValueKind.String => el.GetString(),
                _                                      => el.GetRawText()
            };
        }
        return raw?.ToString();
    }

    private void RecomputeRenderStates()
    {
        if (_version is null) return;
        _renderStates = _evaluator.Evaluate(_version, _values);
    }

    private void HandleFieldValueChanged((string FieldId, object? Value) change)
    {
        _values[change.FieldId] = change.Value;
        _fieldErrors.Remove(change.FieldId);
        _saved = false;
        RecomputeRenderStates();
        StateHasChanged();
    }

    private async Task HandleSave()
    {
        _validationErrors.Clear();
        _fieldErrors = new();

        if (_version is null || string.IsNullOrWhiteSpace(_artifactId)) return;

        foreach (var section in _version.Sections)
        {
            foreach (var field in section.Fields)
            {
                var state = _renderStates.GetValueOrDefault(field.FieldId);
                if (state is null || !state.Visible) continue;

                var rule = field.Validation;
                if (rule is null) continue;

                var value = _values.GetValueOrDefault(field.FieldId)?.ToString();

                if (rule.Required && string.IsNullOrWhiteSpace(value))
                {
                    var msg = $"{field.Label} is required.";
                    _validationErrors.Add(msg);
                    _fieldErrors[field.FieldId] = msg;
                }
                else if (rule.MaxLength.HasValue && value?.Length > rule.MaxLength)
                {
                    var msg = $"{field.Label} exceeds maximum length of {rule.MaxLength}.";
                    _validationErrors.Add(msg);
                    _fieldErrors[field.FieldId] = msg;
                }
                else if (!string.IsNullOrEmpty(rule.RegexPattern) && !string.IsNullOrWhiteSpace(value))
                {
                    if (!System.Text.RegularExpressions.Regex.IsMatch(value, rule.RegexPattern))
                    {
                        var msg = $"{field.Label} format is invalid.";
                        _validationErrors.Add(msg);
                        _fieldErrors[field.FieldId] = msg;
                    }
                }
            }
        }

        if (_validationErrors.Count > 0) return;

        _saving = true;

        // Create submission with labels and values
        var submissionValues = new Dictionary<string, SubmissionFieldData>();
        foreach (var section in _version.Sections)
        {
            foreach (var field in section.Fields)
            {
                if (_values.TryGetValue(field.FieldId, out var value))
                {
                    submissionValues[field.FieldId] = new SubmissionFieldData
                    {
                        Label = field.Label,
                        Value = value
                    };
                }
            }
        }

        var submission = new FormSubmission
        {
            SubmissionId = _existingSubmissionId ?? Guid.NewGuid(), // reuse ID to overwrite existing record
            FormVersionId = _version.FormVersionId,
            FormVersionNumber = _version.VersionNumber,
            ToolType = ToolType,
            FormKey = FormKey,
            RecordPrimaryKey = _artifactId,
            Values = submissionValues,
            SubmittedDate = DateTime.UtcNow,
            SubmittedBy = ""
        };

        await Repository.SaveSubmission(submission);
        _existingSubmissionId = submission.SubmissionId;
        _saving = false;
        _saved = true;
        StateHasChanged();

        var valueDict = submissionValues.ToDictionary(kvp => kvp.Key, kvp => kvp.Value.Value);
        await OnSaved.InvokeAsync(valueDict);

        var labelDict = submissionValues.ToDictionary(kvp => kvp.Value.Label, kvp => kvp.Value.Value);
        await OnSavedByLabel.InvokeAsync(labelDict);
    }

    private async Task HandleCancel()
    {
        await OnCancelled.InvokeAsync();
    }
}

<style>
.fb-artifact-selector {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    padding: 15px;
    background: #f5f5f5;
    border-radius: 4px;
}

.fb-artifact-selector label {
    font-weight: 600;
    min-width: 100px;
}

.fb-artifact-selector input {
    flex: 1;
    padding: 8px 12px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 14px;
}
</style>
