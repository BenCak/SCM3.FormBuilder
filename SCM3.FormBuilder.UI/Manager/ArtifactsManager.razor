@namespace SCM3.FormBuilder.UI.Manager
@using SCM3.FormBuilder.Core.Models
@using SCM3.FormBuilder.Data

@inject IFormRepository Repository

<div class="artifacts-manager">
    <h2>Artifacts</h2>
    
    <div class="artifacts-controls">
        <div class="create-artifact">
            <h3>Create New Artifact</h3>
            <input type="text" placeholder="Artifact ID (e.g., CSCI-2024-001)" @bind="_newArtifactId" />
            <input type="text" placeholder="Name (e.g., Core System CI)" @bind="_newArtifactName" />
            <select @bind="_newArtifactType">
                <option value="CSCI">CSCI</option>
                <option value="Segment">Segment</option>
                <option value="System">System</option>
            </select>
            <button class="fb-btn" @onclick="CreateArtifact">Create</button>
        </div>
    </div>

    @if (_loading)
    {
        <p>Loading artifacts...</p>
    }
    else if (_artifacts == null || _artifacts.Count == 0)
    {
        <p>No artifacts yet. Create one above.</p>
    }
    else
    {
        <div class="artifacts-list">
            <h3>All Artifacts</h3>
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Type</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var artifact in _artifacts)
                    {
                        <tr>
                            <td><strong>@artifact.ArtifactId</strong></td>
                            <td>@artifact.Name</td>
                            <td>@artifact.Type</td>
                            <td>@artifact.CreatedDate:g</td>
                            <td>
                                <button class="fb-btn-small" @onclick="@((e) => SelectArtifact(artifact))">Use</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    [Parameter] public EventCallback<Artifact> OnArtifactSelected { get; set; }

    private List<Artifact>? _artifacts;
    private string _newArtifactId = "";
    private string _newArtifactName = "";
    private string _newArtifactType = "CSCI";
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadArtifacts();
    }

    private async Task LoadArtifacts()
    {
        _loading = true;
        _artifacts = await Repository.ListArtifacts();
        _loading = false;
    }

    private async Task CreateArtifact()
    {
        if (string.IsNullOrWhiteSpace(_newArtifactId) || string.IsNullOrWhiteSpace(_newArtifactName))
        {
            return;
        }

        var artifact = new Artifact
        {
            ArtifactId = _newArtifactId,
            Name = _newArtifactName,
            Type = _newArtifactType,
            CreatedDate = DateTime.UtcNow
        };

        await Repository.SaveArtifact(artifact);
        _newArtifactId = "";
        _newArtifactName = "";
        _newArtifactType = "CSCI";
        await LoadArtifacts();
    }

    private async Task SelectArtifact(Artifact artifact)
    {
        await OnArtifactSelected.InvokeAsync(artifact);
    }
}

<style>
.artifacts-manager {
    padding: 20px;
    border-left: 4px solid #2196F3;
}

.artifacts-controls {
    margin-bottom: 30px;
}

.create-artifact {
    background: #f9f9f9;
    padding: 15px;
    border-radius: 6px;
    border: 1px solid #e0e0e0;
}

.create-artifact h3 {
    margin: 0 0 12px 0;
    font-size: 16px;
}

.create-artifact input {
    display: block;
    width: 100%;
    padding: 10px;
    margin-bottom: 10px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 14px;
    box-sizing: border-box;
}

.create-artifact button {
    width: 100%;
}

.artifacts-list {
    margin-top: 20px;
}

.artifacts-list h3 {
    margin: 0 0 12px 0;
}

.artifacts-list table {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid #ddd;
}

.artifacts-list th {
    background: #f0f0f0;
    padding: 12px;
    text-align: left;
    font-weight: 600;
    border-bottom: 2px solid #ddd;
}

.artifacts-list td {
    padding: 12px;
    border-bottom: 1px solid #f0f0f0;
}

.fb-btn-small {
    padding: 6px 12px;
    font-size: 12px;
    background: #2196F3;
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
}

.fb-btn-small:hover {
    background: #1976D2;
}
</style>
